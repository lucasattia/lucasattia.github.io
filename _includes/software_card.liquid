{% assign software_data = site.data.software %}
{% assign projects = software_data.projects %}
{% assign config = software_data.config %}

{% if config.max_display %}
  {% assign projects = projects | limit: config.max_display %}
{% endif %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap');

  .sw-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin: 2rem 0;
  }

  @media (max-width: 992px) {
    .sw-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .sw-grid { grid-template-columns: 1fr; }
  }

  .sw-card {
    position: relative;
    background: #fff;
    border: 2px solid #111;
    border-radius: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    text-decoration: none !important;
    color: inherit !important;
  }

  .sw-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 6px 6px 0px #111;
    text-decoration: none !important;
  }

  .sw-card-header {
    background: #111;
    padding: 1rem 1.1rem 0.85rem;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .sw-card-name {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.05rem;
    color: #fff;
    line-height: 1.2;
    letter-spacing: -0.01em;
    word-break: break-word;
  }

  .sw-github-icon {
    color: #aaa;
    font-size: 1rem;
    margin-top: 2px;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .sw-card:hover .sw-github-icon {
    color: #fff;
  }

  .sw-card-body {
    padding: 0.9rem 1.1rem 1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sw-description {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    color: #333;
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }

  .sw-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-top: 0.5rem;
    border-top: 1px solid #eee;
  }

  .sw-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .sw-badge {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .sw-role {
    font-family: 'Syne', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.55rem;
    border: 1.5px solid #111;
    color: #111;
    white-space: nowrap;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .sw-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.75rem;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.65rem 1.4rem;
    background: #111;
    color: #fff !important;
    border: 2px solid #111;
    text-decoration: none !important;
    transition: background 0.15s, color 0.15s, transform 0.15s, box-shadow 0.15s;
    border-radius: 0;
  }

  .sw-more-btn:hover {
    background: #fff;
    color: #111 !important;
    transform: translate(-3px, -3px);
    box-shadow: 4px 4px 0 #111;
    text-decoration: none !important;
  }
</style>

<div class="sw-grid">
  {% for project in projects %}
  <a class="sw-card" href="{{ project.url }}" target="_blank" rel="noopener noreferrer">
    <div class="sw-card-header">
      <span class="sw-card-name">{{ project.name }}</span>
      <i class="fab fa-github sw-github-icon"></i>
    </div>
    <div class="sw-card-body">
      <p class="sw-description">{{ project.description }}</p>
      <div class="sw-card-footer">
        <div class="sw-badges">
          {% for lang in project.languages %}
          <span class="sw-badge" style="background-color: {{ lang.color }}18; color: {{ lang.color }}; border: 1.5px solid {{ lang.color }}55;">
            <i class="{{ lang.icon }}" style="margin-right:3px;"></i>{{ lang.name }}
          </span>
          {% endfor %}
        </div>
        {% if project.role %}
        <span class="sw-role">{{ project.role }}</span>
        {% endif %}
      </div>
    </div>
  </a>
  {% endfor %}
</div>

{% if config.show_more_button %}
<div>
  <a href="{{ config.button_link }}" target="_blank" rel="noopener noreferrer" class="sw-more-btn">
    {{ config.button_text }} &nbsp;<i class="fab fa-github"></i>
  </a>
</div>
{% endif %}
